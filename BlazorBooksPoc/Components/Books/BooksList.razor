@page "/books"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@using BlazorBooksPoc.Models
@using BlazorBooksPoc.Services
@using BlazorBooksPoc.Components.Books
@using Microsoft.AspNetCore.Components.Forms
@inject IBookService BookService
@inject NavigationManager Navigation

<div class="mb-3 d-flex justify-content-between align-items-center">
    <div>
        <button type="button" class="btn btn-primary" @onclick="NavigateToCreate">新規作成</button>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label" for="titleFilter">タイトル</label>
            <InputText id="titleFilter" class="form-control" @bind-Value="searchCondition.Title" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="authorFilter">著者</label>
            <InputText id="authorFilter" class="form-control" @bind-Value="searchCondition.Author" />
        </div>
        <div class="col-md-2">
            <label class="form-label" for="isReadFilter">読了状態</label>
            <InputSelect id="isReadFilter" class="form-select" @bind-Value="searchCondition.ReadFilter">
                <option value="@ReadFilter.All">すべて</option>
                <option value="@ReadFilter.Read">読了</option>
                <option value="@ReadFilter.Unread">未読</option>
            </InputSelect>
        </div>
        <div class="col-md-2">
            <label class="form-label" for="sortOrder">並び順</label>
            <InputSelect id="sortOrder" class="form-select" @bind-Value="searchCondition.SortOrder">
                <option value="@SortOrder.CreatedAtDesc">作成日: 新しい順</option>
                <option value="@SortOrder.CreatedAtAsc">作成日: 古い順</option>
            </InputSelect>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-primary w-100" @onclick="Search">検索</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (books is null)
{
    <p>読み込み中...</p>
}
else if (books.Count == 0)
{
    <p>データがありません。</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>タイトル</th>
                <th>著者</th>
                <th>読了</th>
                <th>作成日</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in books)
            {
                <BookListRow Item="item" OnClickEdit="() => NavigateToEdit(item.Id)" OnClickRow="() => NavigateToEdit(item.Id)" />
            }
        </tbody>
    </table>
}

@code {
    private List<Book>? books;
    private BookSearchCondition searchCondition = new()
    {
        Title = string.Empty,
        Author = string.Empty,
        ReadFilter = ReadFilter.All,
        SortOrder = SortOrder.CreatedAtDesc
    };
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooksAsync();
    }

    private async Task Search()
    {
        // 入力された検索条件を元に一覧を再取得する。
        await LoadBooksAsync();
    }

    private async Task LoadBooksAsync()
    {
        errorMessage = null;
        try
        {
            // フィルター条件に応じて一覧を取得する。
            books = await BookService.GetListAsync(
                searchCondition.Title,
                searchCondition.Author,
                searchCondition.ReadFilter,
                searchCondition.SortOrder);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "一覧の取得に失敗しました。時間をおいて再度お試しください。";
            books = new List<Book>();
        }
    }

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/books/create");
    }

    private void NavigateToEdit(int id)
    {
        Navigation.NavigateTo($"/books/edit/{id}");
    }
}
