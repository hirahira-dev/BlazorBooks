@page "/books"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@using BlazorBooksPoc.Models
@using BlazorBooksPoc.Services
@using BlazorBooksPoc.Components.Books
@using Microsoft.AspNetCore.Components.Forms
@inject IBookService BookService
@inject NavigationManager Navigation

<div class="mb-3 d-flex justify-content-between align-items-center">
    <div>
        <button type="button" class="btn btn-primary" @onclick="NavigateToCreate">新規登録</button>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label" for="titleFilter">タイトル</label>
            <InputText id="titleFilter" class="form-control" @bind-Value="titleFilter" />
        </div>
        <div class="col-md-3">
            <label class="form-label" for="authorFilter">著者</label>
            <InputText id="authorFilter" class="form-control" @bind-Value="authorFilter" />
        </div>
        <div class="col-md-2">
            <label class="form-label" for="isReadFilter">読了フラグ</label>
            <InputSelect id="isReadFilter" class="form-select" @bind-Value="isReadFilter">
                <option value="all">すべて</option>
                <option value="read">読了</option>
                <option value="unread">未読</option>
            </InputSelect>
        </div>
        <div class="col-md-2">
            <label class="form-label" for="sortOrder">並び替え</label>
            <InputSelect id="sortOrder" class="form-select" @bind-Value="sortOrder">
                <option value="created_at_desc">登録日 降順</option>
                <option value="created_at_asc">登録日 昇順</option>
            </InputSelect>
        </div>
        <div class="col-md-2">
            <button type="button" class="btn btn-outline-primary w-100" @onclick="Search">検索</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (books is null)
{
    <p>読み込み中...</p>
}
else if (books.Count == 0)
{
    <p>該当する書籍がありません。</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>タイトル</th>
                <th>著者</th>
                <th>読了</th>
                <th>登録日</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in books)
            {
                <BookListRow Item="item" OnClickEdit="() => NavigateToEdit(item.Id)" OnClickRow="() => NavigateToEdit(item.Id)" />
            }
        </tbody>
    </table>
}

@code {
    private List<Book>? books;
    private string titleFilter = string.Empty;
    private string authorFilter = string.Empty;
    private string isReadFilter = "all";
    private string sortOrder = "created_at_desc";
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadBooksAsync();
    }

    private async Task Search()
    {
        await LoadBooksAsync();
    }

    private async Task LoadBooksAsync()
    {
        errorMessage = null;
        try
        {
            bool? isRead = isReadFilter switch
            {
                "read" => true,
                "unread" => false,
                _ => null
            };

            books = await BookService.GetListAsync(titleFilter, authorFilter, isRead, sortOrder);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "一覧の取得に失敗しました。時間をおいて再度お試しください。";
            books = new List<Book>();
        }
    }

    private void NavigateToCreate()
    {
        Navigation.NavigateTo("/books/create");
    }

    private void NavigateToEdit(int id)
    {
        Navigation.NavigateTo($"/books/edit/{id}");
    }
}
