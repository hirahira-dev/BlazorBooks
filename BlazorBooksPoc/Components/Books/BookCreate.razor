@page "/books/create"
@using static Microsoft.AspNetCore.Components.Web.RenderMode
@rendermode InteractiveServer
@using BlazorBooksPoc.Models
@using BlazorBooksPoc.Services
@using BlazorBooksPoc.Components.Books
@inject IBookService BookService
@inject NavigationManager Navigation

<h3>書籍の新規登録</h3>
<p>新しい書籍を登録します。必須項目を入力して保存してください。</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<BookForm Model="book" Title="書籍の新規登録" OnValidSubmit="HandleValidSubmit" />

@code {
    private Book book = default!;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        book = new Book();
    }

    private async Task HandleValidSubmit()
    {
        errorMessage = null;
        try
        {
            await BookService.CreateAsync(book);
            Navigation.NavigateTo("/books");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            errorMessage = "保存に失敗しました。時間をおいて再度お試しください。";
        }
    }
}
